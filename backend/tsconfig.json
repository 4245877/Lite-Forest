{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"]
    
    // МЫ УБРАЛИ typeRoots и types - пусть TS использует настройки по умолчанию
  },
  "include": [
    "src/**/*",         
    "src/types/**/*.d.ts" // Для надёжности явно укажем расширение
  ],
  "exclude": ["node_modules", "dist"]
}